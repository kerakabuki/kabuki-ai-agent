{
  "name": "kabuki-post-365",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run build:frontend && wrangler dev",
    "build:frontend": "cd frontend && npm run build",
    "deploy": "npm run build:frontend && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply kabuki-post-365-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply kabuki-post-365-db --remote"
  },
  "dependencies": {
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@types/node": "^25.3.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.68.1"
  }
}
